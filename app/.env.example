# Tem No Bairro — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com suas credenciais reais
# NUNCA commite o .env.local — ele já está no .gitignore

# ─────────────────────────────────────────
# Supabase — OBRIGATÓRIO
# Painel Supabase → Settings → API
# ─────────────────────────────────────────
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ─────────────────────────────────────────
# Supabase Service Role — APENAS para scripts de seed/admin
# Bypassa o RLS. NUNCA exponha no frontend ou commite o valor real.
# ─────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ─────────────────────────────────────────
# Navegação — URL da landing page raiz
# ─────────────────────────────────────────
VITE_LANDING_URL=https://www.temnobairro.online/

# ─────────────────────────────────────────
# Algolia — OPCIONAL (busca de comércios)
# ─────────────────────────────────────────
VITE_ALGOLIA_APP_ID=
VITE_ALGOLIA_SEARCH_KEY=

# ─────────────────────────────────────────
# Genkit / AI — OPCIONAL
# ─────────────────────────────────────────
VITE_GENKIT_API_URL=
