Options -MultiViews
RewriteEngine On
RewriteBase /interlagos/

# Arquivos estáticos — servir diretamente pela extensão
RewriteRule \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|json|webmanifest|map|txt|xml|wasm)$ - [L]

# Tudo o mais vai para o index.html (SPA fallback)
RewriteRule ^ index.html [L]
